# config.env.example - Przykładowa konfiguracja dla setup-olares.sh
# Użycie: cp config.env.example config.env && edytuj config.env
#         source config.env && sudo -E bash setup-olares.sh
# Lub:    export $(grep -v '^#' config.env | xargs) && sudo -E bash setup-olares.sh

# === Host ===
HOSTNAME="ai-dev-host"
TIMEZONE="Europe/Warsaw"
LOCALE="pl_PL.UTF-8"

# === Katalog bazowy ===
BASE_DIR="/opt/ai-dev-team"

# === Co instalować (true/false) ===
INSTALL_OLARES="false"
INSTALL_DOCKER="true"
INSTALL_K3S="true"
INSTALL_WIREGUARD="true"
INSTALL_OLLAMA="true"
INSTALL_POSTGRES="true"
INSTALL_REDIS="true"
INSTALL_MINIO="true"
INSTALL_N8N="true"
# MinIO root credentials (wymagane w nowszych wersjach)
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"

# === NVIDIA (auto|yes|no) ===
# auto = wykryj GPU i zainstaluj jeśli jest
# yes = zainstaluj zawsze
# no = nie instaluj
INSTALL_NVIDIA="auto"

# === WireGuard ===
WG_INTERFACE="wg0"
WG_PORT="51820"
WG_NETWORK="10.100.0.0"
WG_CIDR="24"
# Interfejs sieciowy wychodzący (eth0, enp0s3, etc.)
# Puste = auto-wykrycie
WG_EXT_IF=""

# === Dla verify-and-start-olares.sh ===
# HOST_IP – adres do podsumowania (puste = auto z hostname -I)
# N8N_DB_USER, N8N_DB_NAME, N8N_DB_PASSWORD – opcjonalna baza dla n8n

# === Sieć (do ręcznej konfiguracji po instalacji, jeśli NET-001 = statyczny IP) ===
# Przykład - ustaw przez netplan lub /etc/network/interfaces:
# STATIC_IP="192.168.1.100/24"
# GATEWAY="192.168.1.1"
# DNS="8.8.8.8 8.8.4.4"
